<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="2026-01-28-0008-attachments" author="gfedorov">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="attachments"/>
            </not>
        </preConditions>

        <createTable tableName="attachments">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="message_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="file_url" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="file_name" type="VARCHAR(255)"/>
            <column name="file_size" type="BIGINT"/>
            <column name="file_type" type="VARCHAR(50)"/>
            <column name="thumbnail_url" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="attachments" baseColumnNames="message_id"
                                 referencedTableName="messages" referencedColumnNames="id"
                                 constraintName="fk_attachments_message" onDelete="CASCADE"/>

        <createIndex tableName="attachments" indexName="idx_attachments_message_id">
            <column name="message_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="attachments"/>
        </rollback>
    </changeSet>
</databaseChangeLog>