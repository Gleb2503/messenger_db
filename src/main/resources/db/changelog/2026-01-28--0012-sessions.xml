<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="2026-01-28-0012-sessions" author="gfedorov">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="sessions"/>
            </not>
        </preConditions>

        <createTable tableName="sessions">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="device_name" type="VARCHAR(100)"/>
            <column name="device_type" type="VARCHAR(50)"/>
            <column name="ip_address" type="VARCHAR(45)"/>
            <column name="user_agent" type="TEXT"/>
            <column name="is_active" type="BOOLEAN" defaultValue="true"/>
            <column name="last_active_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="expires_at" type="TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="sessions" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_sessions_user" onDelete="CASCADE"/>

        <createIndex tableName="sessions" indexName="idx_sessions_user_id">
            <column name="user_id"/>
        </createIndex>
        <createIndex tableName="sessions" indexName="idx_sessions_is_active">
            <column name="is_active"/>
        </createIndex>

        <rollback>
            <dropTable tableName="sessions"/>
        </rollback>
    </changeSet>
</databaseChangeLog>